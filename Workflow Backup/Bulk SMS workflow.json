        "jsCode": "let phone = $json.phone.toString();\n\nif (phone.startsWith(\"254\")) {\n  phone = \"0\" + phone.substring(3);\n}\n\nreturn {\n  json: {\n    ...$json,\n    phone: phone\n  }\n};"
      },
