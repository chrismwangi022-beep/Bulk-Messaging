    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const name = $json.MemberName;\nconst days = Number($json.Days);\n\n\n// ===============================\n// PHONE CLEANING\n// ===============================\n\nlet phone = String($json.MobileNo || '').trim();\n\nphone = phone.replace(/\\D/g,'');\n\nif(phone.startsWith('0')){\n  phone = '254' + phone.substring(1);\n}\n\n\n\n// ===============================\n// PRODUCT RULE ENGINE\n// ===============================\n\nconst product = String(\n  $json.ProductName ||\n  $json.Product ||\n  $json.LoanProduct ||\n  \"\"\n).trim().toLowerCase();\n\n\n\nconst num = (value) => Number(value || 0);\n\n\n\nconst reducingProducts = [\n  \"jijenge loan\",\n  \"okoa\",\n  \"inua loan\",\n  \"okoa plus\"\n];\n\n\nconst flexProducts = [\n  \"flex lending\"\n];\n\n\n\nlet amount;\nlet balanceType;\n\n\n\n// ===============================\n// REDUCING BALANCE\n// Total + Interest\n// ===============================\n\nif (\n  reducingProducts.some(\n    p => product.includes(p)\n  )\n){\n\namount =\nnum($json.Total) +\nnum($json.Interest);\n\n\nbalanceType = \"outstanding\";\n\n}\n\n\n\n// ===============================\n// FLEX LENDING\n// Installment arrears\n// ===============================\n\nelse if (\n  flexProducts.some(\n    p => product.includes(p)\n  )\n){\n\namount =\nnum($json.Installment);\n\n\nbalanceType = \"installment\";\n\n}\n\n\n\n// ===============================\n// FLAT RATE DEFAULT\n// Total\n// ===============================\n\nelse {\n\namount =\nnum($json.Total);\n\n\nbalanceType = \"outstanding\";\n\n}\n\n\n\n// ===============================\n// MONEY FORMAT\n// KES 0,000.00\n// ===============================\n\nconst formattedAmount =\namount.toLocaleString(\n\"en-KE\",\n{\nminimumFractionDigits:2,\nmaximumFractionDigits:2\n}\n);\n\n\n\n// ===============================\n// SMS MESSAGE\n// ===============================\n\n\nlet message = \"\";\n\n\n\nif(balanceType === \"installment\"){\n\n\nmessage =\n`Spread Capital Limited: Dear ${name}, your loan is ${days} day(s) overdue. The total installment arrears as at today are KES ${formattedAmount}. Kindly make payment via Paybill 4016875 to regularize your account. Thank you.`;\n\n\n\n}\n\nelse {\n\n\nmessage =\n`Spread Capital Limited: Dear ${name}, your loan is ${days} day(s) overdue. The total arrears balance as at today is KES ${formattedAmount}. Kindly make payment via Paybill 4016875 to regularize your account. Thank you.`;\n\n\n\n}\n\n\n\nreturn {\n\nphone,\n\nmessage,\n\nSMSRule: balanceType\n\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
